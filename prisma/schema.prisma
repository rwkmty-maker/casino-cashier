// Prisma schema for a small-scale, play-money amusement cashier system.
// Inspired by iGaming PAM / wallet patterns: double-entry ledger, immutable audit trail,
// role-based access, and idempotent transactions.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AccountType {
  HOUSE
  MEMBER
  SITE
}

enum TransactionType {
  BUY
  SELL
  DEPOSIT_TO_SITE
  WITHDRAW_FROM_SITE
  ADJUST
  BONUS
  REVERSAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum SeatStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum SiteStatus {
  ACTIVE
  MAINTENANCE
  DISABLED
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String
  role         UserRole @default(CASHIER)
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionsCreated Transaction[] @relation("CreatedBy")

  @@map("users")
}

model Member {
  id     String       @id @default(cuid())
  code   String       @unique
  name   String
  email  String?
  phone  String?
  status MemberStatus @default(ACTIVE)
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account?
  transactions Transaction[]
  seats Seat[]

  @@map("members")
}

model Site {
  id     String     @id @default(cuid())
  name   String
  slug   String     @unique
  color  String?
  order  Int        @default(0)
  status SiteStatus @default(ACTIVE)
  apiUrl String?
  apiKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account?
  transactions Transaction[]
  seats Seat[]

  @@map("sites")
}

model Seat {
  id        String     @id @default(cuid())
  number    Int        @unique
  name      String
  status    SeatStatus @default(AVAILABLE)
  memberId  String?    @unique
  siteId    String?
  startedAt DateTime?

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@map("seats")
}

model Account {
  id      String      @id @default(cuid())
  type    AccountType
  balance Int         @default(0)

  // Only one account per member and one per site. HOUSE account has both null.
  memberId String? @unique
  siteId   String? @unique

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@map("accounts")
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  status      TransactionStatus @default(COMPLETED)
  amount      Int
  description String?

  memberId String?
  siteId   String?
  relatedTransactionId String? @unique

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdBy User @relation("CreatedBy", fields: [createdById], references: [id])
  relatedTransaction Transaction? @relation("Reversal", fields: [relatedTransactionId], references: [id], onDelete: SetNull)
  reversalOf Transaction? @relation("Reversal")

  ledgerEntries LedgerEntry[]

  @@map("transactions")
}

model LedgerEntry {
  id           String @id @default(cuid())
  transactionId String
  accountId    String
  debit        Int    @default(0)
  credit       Int    @default(0)
  balanceAfter Int

  createdAt DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
}
